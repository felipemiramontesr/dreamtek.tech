<IfModule mod_rewrite.c>
RewriteEngine On

# 1. Redirección para la página principal (/)
# Si el usuario tiene la cookie "en" guardada
RewriteCond %{REQUEST_URI} ^/$ [OR]
RewriteCond %{REQUEST_URI} ^/index\.html$
RewriteCond %{HTTP_COOKIE} dreamtek_lang_preference=en [NC]
RewriteRule ^(.*)$ /en/ [R=302,L]

# Si no hay cookie pero su navegador prefiere inglés
RewriteCond %{REQUEST_URI} ^/$ [OR]
RewriteCond %{REQUEST_URI} ^/index\.html$
RewriteCond %{HTTP_COOKIE} !dreamtek_lang_preference [NC]
RewriteCond %{HTTP:Accept-Language} ^en [NC]
RewriteRule ^(.*)$ /en/ [R=302,L]

# 2. Redirección para /privacidad
RewriteCond %{REQUEST_URI} ^/privacidad/?$
RewriteCond %{HTTP_COOKIE} dreamtek_lang_preference=en [NC]
RewriteRule ^(.*)$ /en/privacidad/ [R=302,L]

RewriteCond %{REQUEST_URI} ^/privacidad/?$
RewriteCond %{HTTP_COOKIE} !dreamtek_lang_preference [NC]
RewriteCond %{HTTP:Accept-Language} ^en [NC]
RewriteRule ^(.*)$ /en/privacidad/ [R=302,L]

# 3. Redirección para /terminos
RewriteCond %{REQUEST_URI} ^/terminos/?$
RewriteCond %{HTTP_COOKIE} dreamtek_lang_preference=en [NC]
RewriteRule ^(.*)$ /en/terminos/ [R=302,L]

RewriteCond %{REQUEST_URI} ^/terminos/?$
RewriteCond %{HTTP_COOKIE} !dreamtek_lang_preference [NC]
RewriteCond %{HTTP:Accept-Language} ^en [NC]
RewriteRule ^(.*)$ /en/terminos/ [R=302,L]

# 4. Redirección para /cookies
RewriteCond %{REQUEST_URI} ^/cookies/?$
RewriteCond %{HTTP_COOKIE} dreamtek_lang_preference=en [NC]
RewriteRule ^(.*)$ /en/cookies/ [R=302,L]

RewriteCond %{REQUEST_URI} ^/cookies/?$
RewriteCond %{HTTP_COOKIE} !dreamtek_lang_preference [NC]
RewriteCond %{HTTP:Accept-Language} ^en [NC]
RewriteRule ^(.*)$ /en/cookies/ [R=302,L]
</IfModule>

# ----------------------------------------------------------------------
# Control de Caché para Assets Estáticos (Next.js Export)
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # Imágenes y Fuentes (1 año)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/x-font-otf "access plus 1 year"
    
    # CSS y JavaScript (1 año, ya que next.js inyecta hash en el filename)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"

    # HTML (Forzar re-validación siempre)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Assets inmutables con hash y recursos multimedia
    <FilesMatch "\.(css|js|webp|svg|woff2|otf|png|jpg|jpeg)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Documentos HTML
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
